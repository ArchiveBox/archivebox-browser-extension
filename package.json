{
  "name": "archivebox-browser-extension",
  "description": "Collect URLs and preserve them using a remote ArchiveBox server",
  "private": true,
  "version": "3.0.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "zip:stores": "pnpm zip && pnpm zip:firefox",
    "submit:chrome": "wxt submit --chrome-extension-id habonpimjphpdnmcfkaockjnffodikoj --chrome-zip .output/archivebox-browser-extension-3.0.1-chrome.zip",
    "submit:firefox": "wxt submit --firefox-extension-id archivebox@tjhorner.dev --firefox-zip .output/archivebox-browser-extension-3.0.1-firefox.zip --firefox-sources-zip .output/archivebox-browser-extension-3.0.1-sources.zip",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "^5.9.3",
    "wxt": "^0.20.26"
  }
}
